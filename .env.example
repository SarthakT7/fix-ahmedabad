# Fix Ahmedabad — environment variables
# Copy this file to .env.local and fill in the values.

# ─── Supabase (public, safe to expose in the browser) ──────────────────────
# Get these from Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# ─── Supabase (server only — NEVER expose in the browser) ──────────────────
# Used by the /api/reports route to insert reports and to clean up rejected
# image uploads, and to run scripts/parse-and-seed-councillors.mjs locally.
# This key bypasses Row Level Security, so keep it out of any client bundle.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Replicate (server only — NEVER expose in the browser) ─────────────────
# Powers the cheap CLIP image gate that rejects non-garbage photos (screenshots,
# memes, solid colors). If unset, the gate is skipped and all photos are allowed.
# Get a token at https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=your-replicate-api-token
